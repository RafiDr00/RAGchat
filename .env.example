# Root env — copy relevant sections to backend/.env and frontend/.env.local

# ── Backend (backend/.env) ─────────────────────────────────────────────────
RAGCHAT_API_KEY=change-me-to-random-string   # Required — protects ingest/clear endpoints
OPENAI_API_KEY=sk-...                        # Required — GPT-4o for generation
OPENAI_MODEL=gpt-4o
QDRANT_PATH=./qdrant_db
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (frontend/.env.local) ────────────────────────────────────────
BACKEND_URL=http://localhost:8001
NEXT_PUBLIC_RAGCHAT_API_KEY=change-me-to-random-string  # Must match RAGCHAT_API_KEY above
